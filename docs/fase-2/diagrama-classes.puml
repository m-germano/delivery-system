@startuml
title Diagrama de Classes — DishDash

skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam shadowing false

top to bottom direction

package "Acesso" {
  class Role {
    +id: smallint
    +name: string
    +description: string
  }

  class User {
    +id: bigint
    +role_id: smallint
    +name: string
    +email: string
    +password_hash: string
    +phone: string
    +is_active: boolean
    +created_at: datetime
    +updated_at: datetime
  }
}

package "Empresa e Catálogo" {
  class Company {
    +id: bigint
    +owner_user_id: bigint
    +name: string
    +description: text
    +phone: string
    +document: string
    +image_url: string
    +is_active: boolean
    +is_open: boolean
    +created_at: datetime
    +updated_at: datetime
  }

  class CompanyAddress {
    +id: bigint
    +company_id: bigint
    +street: string
    +number: string
    +complement: string
    +neighborhood: string
    +city: string
    +state: string
    +zip_code: string
    +latitude: decimal
    +longitude: decimal
  }

  class CompanyOrderSettings {
    +id: bigint
    +company_id: bigint
    +accepts_delivery: boolean
    +accepts_pickup: boolean
    +pickup_discount_percent: decimal
    +minimum_order_value: decimal
  }

  class ProductCategory {
    +id: bigint
    +company_id: bigint
    +name: string
    +description: text
    +display_order: int
    +is_active: boolean
  }

  class Product {
    +id: bigint
    +company_id: bigint
    +category_id: bigint
    +name: string
    +description: text
    +price: decimal
    +image_url: string
    +is_active: boolean
  }

  class DeliveryFeeRule {
    +id: bigint
    +company_id: bigint
    +min_distance_km: decimal
    +max_distance_km: decimal
    +fee: decimal
    +is_active: boolean
  }
}

package "Cliente" {
  class CustomerAddress {
    +id: bigint
    +user_id: bigint
    +label: string
    +street: string
    +number: string
    +complement: string
    +neighborhood: string
    +city: string
    +state: string
    +zip_code: string
    +latitude: decimal
    +longitude: decimal
    +is_default: boolean
  }

  class CompanyReview {
    +id: bigint
    +company_id: bigint
    +customer_user_id: bigint
    +order_id: bigint
    +rating: int
    +comment: text
    +created_at: datetime
  }
}

package "Pedidos" {
  class Order {
    +id: bigint
    +customer_user_id: bigint
    +company_id: bigint
    +customer_address_id: bigint
    +fulfillment_type: string
    +status: string
    +subtotal: decimal
    +discount_amount: decimal
    +pickup_discount_percent: decimal
    +delivery_fee: decimal
    +total: decimal
    +distance_km: decimal
    +payment_method: string
    +notes: text
    +created_at: datetime
    +updated_at: datetime
  }

  class OrderItem {
    +id: bigint
    +order_id: bigint
    +product_id: bigint
    +product_name: string
    +unit_price: decimal
    +quantity: int
    +total_price: decimal
    +notes: text
  }

  class OrderStatusHistory {
    +id: bigint
    +order_id: bigint
    +old_status: string
    +new_status: string
    +changed_by_user_id: bigint
    +created_at: datetime
  }
}

package "Entrega" {
  class Courier {
    +id: bigint
    +user_id: bigint
    +vehicle_type: string
    +vehicle_plate: string
    +is_available: boolean
    +current_latitude: decimal
    +current_longitude: decimal
  }

  class Delivery {
    +id: bigint
    +order_id: bigint
    +courier_user_id: bigint
    +status: string
    +pickup_latitude: decimal
    +pickup_longitude: decimal
    +destination_latitude: decimal
    +destination_longitude: decimal
    +distance_km: decimal
    +delivery_fee: decimal
    +accepted_at: datetime
    +picked_up_at: datetime
    +delivered_at: datetime
  }

  class DeliveryStatusHistory {
    +id: bigint
    +delivery_id: bigint
    +old_status: string
    +new_status: string
    +changed_by_user_id: bigint
    +created_at: datetime
  }
}

package "Pagamento" {
  class CompanyPaymentAccount {
    +id: bigint
    +company_id: bigint
    +provider: string
    +provider_user_id: string
    +public_key: text
    +access_token_encrypted: text
    +refresh_token_encrypted: text
    +token_expires_at: datetime
    +is_active: boolean
  }

  class PaymentOAuthState {
    +id: bigint
    +company_id: bigint
    +user_id: bigint
    +provider: string
    +state: string
    +code_verifier_encrypted: text
    +expires_at: datetime
    +consumed_at: datetime
  }

  class Payment {
    +id: bigint
    +order_id: bigint
    +company_id: bigint
    +provider: string
    +provider_payment_id: string
    +provider_order_id: string
    +idempotency_key: string
    +payment_method: string
    +status: string
    +amount: decimal
    +currency: string
    +checkout_preference_id: string
    +checkout_url: text
    +raw_response: json
  }
}

Role "1" <-- "0..*" User
User "1" -- "0..1" Company : owner
Company "1" -- "1" CompanyAddress
Company "1" -- "1" CompanyOrderSettings
Company "1" -- "0..*" ProductCategory
Company "1" -- "0..*" Product
Company "1" -- "0..*" DeliveryFeeRule
ProductCategory "1" -- "0..*" Product

User "1" -- "0..*" CustomerAddress
User "1" -- "0..1" Courier

Company "1" -- "0..*" Order
User "1" -- "0..*" Order : customer
CustomerAddress "0..1" -- "0..*" Order
Order "1" -- "1..*" OrderItem
Product "1" -- "0..*" OrderItem
Order "1" -- "0..*" OrderStatusHistory

Order "1" -- "0..1" Delivery
User "0..1" -- "0..*" Delivery : courier_user
Delivery "1" -- "0..*" DeliveryStatusHistory

Company "1" -- "0..*" CompanyPaymentAccount
Company "1" -- "0..*" PaymentOAuthState
Order "1" -- "0..*" Payment
Company "1" -- "0..*" Payment

Company "1" -- "0..*" CompanyReview
User "1" -- "0..*" CompanyReview : customer
Order "1" -- "0..1" CompanyReview

@enduml
